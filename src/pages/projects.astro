---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import TimelineVertical from "../components/TimelineVertical.astro";
import TimelineYearMarker from "../components/TimelineYearMarker.astro";
import { projects } from "../data/projects";
import { Icon } from "astro-icon/components";

function getYear(date?: string): number | null {
  if (!date) return null;
  const match = date.match(/\d{4}/);
  return match ? parseInt(match[0]) : null;
}

const projectsByYear: { year: number | null; projects: typeof projects }[] = [];
let currentYear: number | null = undefined as any;

for (const project of projects) {
  const year = getYear(project.date);
  if (year !== currentYear) {
    currentYear = year;
    projectsByYear.push({ year, projects: [] });
  }
  projectsByYear[projectsByYear.length - 1].projects.push(project);
}
---

<BaseLayout title="Tansvi Sheoran - Projects" activePage="projects">
  <div class="max-w-7xl mx-auto px-4 mt-3">
    <h1
      class="text-center text-3xl md:text-4xl font-medium text-dark-text mb-4"
    >
      Projects
    </h1>
    <TimelineVertical>
      {
        projectsByYear.map((group) => (
          <div>
            {group.year && <TimelineYearMarker year={group.year} />}
            {group.projects.map((project) => (
              <div class="timeline-item relative mb-7">
                <Card>
                  <details class="career-accordion group">
                    <summary class="cursor-pointer list-none text-center">
                      <h5 class="text-lg font-medium text-dark-text">
                        {project.title}
                      </h5>
                      {project.date && (
                        <p class="text-sm text-dark-text-muted">
                          {project.date}
                        </p>
                      )}
                      {project.githubUrl && (
                        <a
                          href={project.githubUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`View ${project.title} GitHub repository`}
                          class="text-dark-text-secondary hover:text-dark-accent transition-colors duration-200 inline-block mt-1"
                          onclick="event.stopPropagation()"
                        >
                          <Icon name="bi:github" class="w-6 h-6 inline-block" />
                        </a>
                      )}
                      <svg
                        class="career-chevron mx-auto mt-2 w-5 h-5 text-dark-accent transition-transform duration-300"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M19 9l-7 7-7-7"
                        />
                      </svg>
                    </summary>
                    <div class="career-accordion-body text-justify mt-4 text-dark-text-secondary">
                      <p>{project.description}</p>
                      {project.bullets && (
                        <ul class="list-disc text-left ml-5 space-y-1 mt-1">
                          {project.bullets.map((bullet) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                      )}
                      {project.contributors && (
                        <p class="text-left mt-2">
                          <b>Other contributors:</b> {project.contributors}
                        </p>
                      )}
                    </div>
                  </details>
                </Card>
              </div>
            ))}
          </div>
        ))
      }
    </TimelineVertical>
  </div>
</BaseLayout>
