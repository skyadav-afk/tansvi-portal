---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import TimelineVertical from "../components/TimelineVertical.astro";
import TimelineYearMarker from "../components/TimelineYearMarker.astro";
import { careerEntries } from "../data/career";

function getStartYear(dateRange: string): number | null {
  const match = dateRange.match(/\d{4}/);
  return match ? parseInt(match[0]) : null;
}

const entriesByYear: {
  year: number | null;
  entries: typeof careerEntries;
}[] = [];
let currentYear: number | null = undefined as any;

for (const entry of careerEntries) {
  const year = getStartYear(entry.dateRange);
  if (year !== currentYear) {
    currentYear = year;
    entriesByYear.push({ year, entries: [] });
  }
  entriesByYear[entriesByYear.length - 1].entries.push(entry);
}
---

<BaseLayout title="Tansvi Sheoran - Career" activePage="career">
  <div class="max-w-7xl mx-auto px-4 mt-3">
    <h1
      class="text-center text-3xl md:text-4xl font-medium text-dark-text mb-4"
    >
      Career
    </h1>
    <TimelineVertical>
      {
        entriesByYear.map((group) => (
          <div>
            {group.year && <TimelineYearMarker year={group.year} />}
            {group.entries.map((entry) => {
              const hasDetails = entry.description || entry.bullets;
              return (
                <div class="timeline-item relative mb-7">
                  <Card>
                    {hasDetails ? (
                      <details class="career-accordion group">
                        <summary class="cursor-pointer list-none text-center">
                          <h5 class="text-lg font-semibold text-dark-text">
                            {entry.title}
                          </h5>
                          <p class="text-sm text-dark-text-muted flex items-center justify-center gap-2">
                            {entry.logo && (
                              <img
                                src={`${import.meta.env.BASE_URL}${entry.logo}`}
                                alt={entry.organization}
                                class="w-12 h-8 rounded object-contain bg-white px-2 py-0.5"
                              />
                            )}
                            <span>
                              {entry.organization}
                              {entry.dateRange && (
                                <Fragment>
                                  &nbsp;&middot; {entry.dateRange}
                                </Fragment>
                              )}
                            </span>
                          </p>
                          {entry.project && (
                            <p class="text-sm text-dark-text-muted mt-1">
                              Project: {entry.project}
                            </p>
                          )}
                          <svg
                            class="career-chevron mx-auto mt-2 w-5 h-5 text-dark-accent transition-transform duration-300"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M19 9l-7 7-7-7"
                            />
                          </svg>
                        </summary>
                        <div class="career-accordion-body text-justify mt-4 text-dark-text-secondary">
                          {entry.bulletPrefix && <p>{entry.bulletPrefix}</p>}
                          {entry.description &&
                            entry.description.map((paragraph, i) => (
                              <p class={i > 0 ? "mt-2" : ""}>{paragraph}</p>
                            ))}
                          {entry.bullets && (
                            <ul
                              class:list={[
                                "list-disc text-left ml-5 space-y-1",
                                entry.bulletPrefix && "mt-1",
                              ]}
                            >
                              {entry.bullets.map((bullet) => (
                                <li>{bullet}</li>
                              ))}
                            </ul>
                          )}
                        </div>
                      </details>
                    ) : (
                      <div class="text-center">
                        <h5 class="text-lg font-semibold text-dark-text">
                          {entry.title}
                        </h5>
                        <p class="text-sm text-dark-text-muted flex items-center justify-center gap-2">
                          {entry.logo && (
                            <img
                              src={`${import.meta.env.BASE_URL}${entry.logo}`}
                              alt={entry.organization}
                              class="w-12 h-8 rounded object-contain bg-white px-2 py-0.5"
                            />
                          )}
                          <span>
                            {entry.organization}
                            {entry.dateRange && (
                              <Fragment>
                                &nbsp;&middot; {entry.dateRange}
                              </Fragment>
                            )}
                          </span>
                        </p>
                      </div>
                    )}
                  </Card>
                </div>
              );
            })}
          </div>
        ))
      }
    </TimelineVertical>
  </div>
</BaseLayout>
