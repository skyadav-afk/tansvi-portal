---
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import SkillBadge from "../components/SkillBadge.astro";
import CertificationBadge from "../components/CertificationBadge.astro";
import {
  domains,
  technologies,
  languages,
  publications,
  featuredCertifications,
} from "../data/skills";
import { Icon } from "astro-icon/components";
---

<BaseLayout title="Tansvi Sheoran - About" activePage="about">
  <div class="max-w-7xl mx-auto px-4 mt-6">
    <div class="flex justify-center">
      <div class="w-full md:w-2/3">
        <Card>
          <div class="text-center">
            <h1 class="text-4xl md:text-5xl font-medium text-dark-text">
              Tansvi Sheoran
            </h1>
            <p class="text-lg md:text-xl text-dark-text-secondary mt-1">
              Final-year B.Com Hons student at University of Delhi — Valuation &amp; KPI analytics
            </p>
            {
              featuredCertifications.map((cert) => (
                <CertificationBadge
                  text={cert.text}
                  badgeUrl={cert.badgeUrl}
                  certificateUrl={cert.certificateUrl}
                  badgeAlt={cert.badgeAlt}
                  textSize={cert.textSize}
                />
              ))
            }
            <h2 class="text-left text-lg font-bold text-dark-text mt-4">
              About
            </h2>
            <div class="text-justify text-dark-text-secondary space-y-3">
              <p>
                Final-year B.Com Hons student at University of Delhi with hands-on experience in DCF valuation, KPI analytics, and strategic analysis. Founder of Stratlytic AI, an MBB-style consulting tool built on GenAI, with demonstrated ability to deliver structured, data-driven insights in fast-turnaround environments.
              </p>
              <p>
                Business Valuation &amp; Financial Modelling — Tata Motors | Independent 2026<br />
                • Developed an integrated data analytics model synthesising multi-variable inputs (WACC, commodity prices, demand scenarios) into a defensible valuation range applying quantitative methods to drive investment-grade output.<br />
                • Conducted scenario and sensitivity analysis across three business cases, stress-testing value drivers to assess downside risk and produce actionable insights for stakeholder decision-making.
              </p>
              <p>
                Marketing Strategy Analysis — Nykaa | Independent 2026<br />
                • Mapped Nykaa's competitive positioning across India's beauty e-commerce landscape, quantifying CAC and LTV dynamics to identify structural margin pressure from rising acquisition costs and D2C brand competition.<br />
                • Developed a data-driven retention and profitability framework recommending loyalty-led acquisition strategy, identifying an estimated 15–20% reduction in CAC achievable through retention-first growth reallocation.
              </p>
              <!-- Stratlytic AI paragraph removed per user request -->
              <p>
                Strategy Consulting Virtual Experience | BCG (Forage) — Mar–Apr 2026<br />
                • Applied structured profitability frameworks to diagnose revenue decline, synthesising financial and market data to evaluate growth and cost levers, and delivered consulting-grade recommendations on pricing strategy and operational efficiency under fast-turnaround conditions.
              </p>
              <p>
                Public Relations Intern | Techsharks Services Pvt. Ltd. — Jan–Apr 2025<br />
                • Analysed campaign performance across 25+ accounts using Google Analytics and Meltwater, identifying optimisations that drove 30% improvement in media pitch conversion and delivering 50+ data-driven strategy presentations with 95% client retention.
              </p>
              <p>
                Human Resource Intern | Pulp Strategy Pvt. Ltd. — Aug–Nov 2024<br />
                • Analysed KPI and performance data across 200+ employees using Advanced Excel and managed structured data for 500+ candidate profiles, producing senior stakeholder reports with zero-defect accuracy standards and contributing to a 40% reduction in hiring cycle time.
              </p>
              <p>
                Business Development Intern | Broz Media Marketing Agency — Apr–Jul 2024<br />
                • Conducted competitive intelligence and market sizing data analytics to inform organic growth strategy; identified and converted high-value clients through structured, insight-driven outreach — contributing directly to revenue growth.
              </p>
              <p>
                Education &amp; Skills — B.Com Hons 2023–2026 (Satyawati College, University of Delhi), AISSCE/CBSE 2022 (90.5%), AISSE/CBSE 2020 (93.2%). Skills: DCF modelling, WACC estimation, three-statement modelling, sensitivity &amp; scenario analysis, customer acquisition analytics, KPI analytics, SQL, R, Python (basic), MS Office, Power BI, Google Analytics, stakeholder communication, cross-functional collaboration.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>

    <div class="flex justify-center">
      <div class="w-full md:w-2/3">
        <Card class="mt-3">
          <div class="text-center">
            <h2 class="text-2xl font-semibold text-dark-text">Skills</h2>

            <h3 class="text-lg font-medium text-dark-text-secondary mt-4 mb-2">
              Domains & Expertise
            </h3>
            <div>
              {
                domains.map((skill) => (
                  <SkillBadge
                    label={skill.label}
                    icon={skill.icon}
                    iconType={skill.iconType}
                  />
                ))
              }
            </div>

            <h3 class="text-lg font-medium text-dark-text-secondary mt-6 mb-2">
              Technologies & Tools
            </h3>
            <div class="flex flex-wrap justify-center">
              {
                technologies.map((skill) => (
                  <SkillBadge
                    label={skill.label}
                    icon={skill.icon}
                    iconType={skill.iconType}
                  />
                ))
              }
            </div>
          </div>
        </Card>
      </div>
    </div>

    <div class="flex justify-center">
      <div class="w-full md:w-2/3">
        <Card class="mt-3">
          <div class="text-center">
            <h2 class="text-2xl font-semibold text-dark-text">Publications</h2>
            {
              publications.map((pub) => (
                <details class="career-accordion group mt-4">
                  <summary class="cursor-pointer list-none text-center">
                    <h5 class="text-lg font-semibold text-dark-text">
                      {pub.title}
                    </h5>
                    <p class="text-sm text-dark-text-muted">
                      {pub.journal} - {pub.date}
                    </p>
                    <a
                      href={pub.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`View ${pub.title} paper`}
                      class="text-dark-text-secondary hover:text-dark-accent transition-colors duration-200 inline-block mt-1"
                      onclick="event.stopPropagation();"
                    >
                      <Icon
                        name="bi:file-earmark-text"
                        class="w-5 h-5 inline-block"
                      />
                    </a>
                    <svg
                      class="career-chevron mx-auto mt-2 w-5 h-5 text-dark-accent transition-transform duration-300"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </summary>
                  <div class="career-accordion-body text-justify mt-4 text-dark-text-secondary">
                    <p>{pub.abstract}</p>
                  </div>
                </details>
              ))
            }
          </div>
        </Card>
      </div>
    </div>

    <div class="flex justify-center">
      <div class="w-full md:w-2/3">
        <Card class="mt-3">
          <div class="text-center">
            <h2 class="text-2xl font-semibold text-dark-text">Languages</h2>
            <div class="mt-3">
              {
                languages.map((lang) => (
                  <SkillBadge label={`${lang.flag} ${lang.name}`} />
                ))
              }
            </div>
          </div>
        </Card>
      </div>
    </div>
  </div>
</BaseLayout>
